{
    "do this block": {
        "prefix": "do",
        "body": [
            "do this",
            "\t$0",
            "thanks"
        ],
        "description": "Create a polite code block"
    },
    "if statement": {
        "prefix": "if",
        "body": [
            "if ($1) do this",
            "\t$0",
            "thanks"
        ],
        "description": "Polite if statement"
    },
    "if otherwise statement": {
        "prefix": "ifo",
        "body": [
            "if ($1) do this",
            "\t$2",
            "thanks otherwise do this",
            "\t$0",
            "thanks"
        ],
        "description": "Polite if-otherwise statement"
    },
    "while loop": {
        "prefix": "while",
        "body": [
            "while ($1) do this",
            "\t$0",
            "thanks"
        ],
        "description": "Polite while loop"
    },
    "function declaration": {
        "prefix": "func",
        "body": [
            "${1|int,float,string,bool,void|} ${2:name}() do this",
            "\t$0",
            "\treturn pls",
            "thanks"
        ],
        "description": "Declare a new polite function"
    },
    "say print": {
        "prefix": "say",
        "body": [
            "say($1) pls$0"
        ],
        "description": "Print statement"
    }
}