{
  "name": "vscode-polite",
  "displayName": "poLite Language Support",
  "description": "Official Visual Studio Code extension for the poLite programming language. Provides polite syntax highlighting and code snippets.",
  "version": "1.0.0",
  "publisher": "chamered",
  "repository": {
    "type": "git",
    "url": "https://github.com/chamered/vscode-polite.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [{
      "id": "polite",
      "aliases": ["poLite", "polite"],
      "extensions": [".plt"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "polite",
      "scopeName": "source.polite",
      "path": "./syntaxes/polite.tmLanguage.json"
    }],
    "snippets": [{
      "language": "polite",
      "path": "./snippets.json"
    }]
  }
}
