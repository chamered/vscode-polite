{
  "name": "polite-lang",
  "displayName": "poLite",
  "description": "poLite Language Support",
  "version": "1.0.0",
  "publisher": "chamered",
  "repository": {
    "type": "git",
    "url": "https://github.com/chamered/polite-vscode-extension.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "polite",
      "aliases": ["poLite", "polite"],
      "extensions": [".plt"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "polite",
      "scopeName": "source.polite",
      "path": "./syntaxes/polite.tmLanguage.json"
    }],
    "snippets": [{
      "language": "polite",
      "path": "./snippets.json"
    }]
  }
}
