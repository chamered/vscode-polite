{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "poLite",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.polite",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.polite",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.polite",
                    "match": "\\\\."
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.polite",
                    "match": "\\b(if|otherwise|while|return|say)\\b"
                },
                {
                    "name": "keyword.other.polite",
                    "match": "\\b(do\\s+this|thanks|pls)\\b"
                },
                {
                    "name": "storage.modifier.polite",
                    "match": "\\b(const)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.polite",
                    "match": "\\b(int|float|bool|string|void)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.polite",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.numeric.float.polite",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.polite",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.polite",
                    "match": "(&&|\\|\\||!)"
                },
                {
                    "name": "keyword.operator.comparison.polite",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.math.polite",
                    "match": "(\\+|-|\\*|/)"
                },
                {
                    "name": "keyword.operator.assignment.polite",
                    "match": "(=)"
                },
                {
                    "name": "keyword.operator.ternary.polite",
                    "match": "(\\?|:)"
                }
            ]
        }
    },
    "scopeName": "source.polite"
}